<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="500.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.inkilaaa.Muistikortit.Controller.KysymysController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 30; -fx-font-weight: bold;" text="Harjoitus" />

    <VBox alignment="CENTER" spacing="30.0" VBox.vgrow="ALWAYS">
        <children>
            <HBox alignment="CENTER" spacing="20.0">
                <children>

                    <VBox alignment="CENTER" minHeight="250.0" minWidth="400.0" spacing="15.0" style="-fx-border-color: #cccccc; -fx-border-radius: 10; -fx-background-color: #ffffff; -fx-padding: 20;">
                        <children>
                            <Label fx:id="kysymysLabel" style="-fx-font-size: 20; -fx-font-weight: bold;" text="Kysymys" textAlignment="CENTER" wrapText="true" />

                            <Label fx:id="kuvausLabel" style="-fx-font-size: 20; -fx-font-weight: bold;" text="Sanan kuvaus tulee tähän" textAlignment="CENTER" visible="false" wrapText="true" />

                            <Region prefHeight="10.0" />
                        </children>
                    </VBox>
                </children>
            </HBox>
        </children>
    </VBox>

    <HBox alignment="BOTTOM_CENTER" prefHeight="23.0" prefWidth="449.0" spacing="20.0">
        <children>
            <HBox spacing="10.0" />
            <Region HBox.hgrow="ALWAYS" />
              <Button fx:id="edellinenButton" alignment="TOP_CENTER" onAction="#handleEdellinenKortti" prefHeight="18.0" prefWidth="100.0" text="Edellinen" textOverrun="WORD_ELLIPSIS" />

            <Button fx:id="kaannaButton" onAction="#handleKaannaKortti" prefHeight="1.0" prefWidth="110.0" text="Näytä kuvaus" />

              <Button fx:id="seuraavaButton" onAction="#handleSeuraavaKortti" prefHeight="0.0" prefWidth="100.0" text="Seuraava" />
            <Button fx:id="lopetaButton" onAction="#handleLopeta" prefHeight="10.0" prefWidth="110.0" text="Lopeta harjoitus" />
        </children>
    </HBox>
</VBox>
